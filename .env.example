# --- OpenAI / OpenRouter (generación de clases) ---
OPENAI_API_KEY=
# Opcional: fallback
OPENROUTER_API_KEY=

# --- Mercado Pago (suscripciones) ---
# Access token del vendedor. Usa TEST-... en desarrollo, APP_USR-... en producción.
MP_ACCESS_TOKEN=
# Secret del webhook (panel MP → Webhooks → Configurar notificaciones → Clave secreta).
# Distinto por modo (test/prod).
MP_WEBHOOK_SECRET=
# Link público del preapproval creado manualmente en el panel de MP.
# Expuesto al cliente como NEXT_PUBLIC_MP_SUBSCRIPTION_URL.
NEXT_PUBLIC_MP_SUBSCRIPTION_URL=

# --- JWT de acceso ---
# Mínimo 32 caracteres. Generar con: openssl rand -base64 48
ACCESS_JWT_SECRET=
ACCESS_JWT_ISSUER=aula.mx
# Opcional: lista de jti (UUIDs) separados por coma para kill-switch sin DB.
REVOKED_JTIS=

# --- Email transaccional (Resend) ---
RESEND_API_KEY=
# Remitente verificado en Resend
RESEND_FROM=Aula <acceso@aula.mx>

# --- URL canónica de la app (para links en el email) ---
APP_BASE_URL=http://localhost:3000

# --- Supabase (historial y biblioteca de clases) ---
# Proyecto dedicado para Aula. Si están vacías, la app sigue funcionando
# pero sin persistir clases (modo "solo generación").
SUPABASE_URL=
# service_role key (server-only, nunca exponer al cliente)
SUPABASE_SERVICE_ROLE_KEY=
# anon/publishable key (opcional; reservado por si después se usa Auth de Supabase)
SUPABASE_ANON_KEY=
